{
  "name": "@nexpb/xstate-react-patched",
  "version": "3.4.0",
  "description": "XState tools for React (patched)",
  "keywords": [
    "state",
    "machine",
    "statechart",
    "scxml",
    "state",
    "graph",
    "react",
    "hook"
  ],
  "author": "David Khourshid <davidkpiano@gmail.com>",
  "contributors": [
    "Lorenzo De Loof <lorenzo@nexp.be>"
  ],
  "homepage": "https://github.com/NexPB/xstate-react-patched#readme",
  "license": "MIT",
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./es/index.js",
      "require": "./lib/index.js",
      "types": "./lib/index.d.ts"
    },
    "./fsm": {
      "import": "./es/fsm.js",
      "require": "./lib/fsm.js",
      "types": "./lib/fsm.d.ts"
    }
  },
  "typesVersions": {
    "<4.0": {
      "lib/index.d.ts": [
        "index.v3.d.ts"
      ]
    }
  },
  "sideEffects": false,
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "files": [
    "lib/**/*.js",
    "lib/**/*.d.ts",
    "dist/**/*.js",
    "es/**/*.js",
    "es/**/*.d.ts",
    "fsm/package.json"
  ],
  "repository": {
  "type": "git",
  "url": "https://github.com/NexPB/xstate-react-patched"
  },
  "scripts": {
    "clean": "rm -rf dist lib tsconfig.tsbuildinfo",
    "build": "tsc && tsc --outDir es --module es2015 && rollup -c rollup.config.mjs",
    "test": "jest"
  },
  "bugs": {
  "url": "https://github.com/NexPB/xstate-react-patched/issues"
  },
  "peerDependencies": {
    "@xstate/fsm": "^2.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "xstate": "^4.37.2"
  },
  "peerDependenciesMeta": {
    "@xstate/fsm": {
      "optional": true
    },
    "xstate": {
      "optional": true
    }
  },
  "dependencies": {
    "use-isomorphic-layout-effect": "^1.2.0",
    "use-sync-external-store": "^1.6.0"
  },
  "overrides": {
    "glob": "^13.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^26.0.24",
    "@types/jsdom": "^12.2.3",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/use-sync-external-store": "^1.5.0",
    "@xstate/fsm": "^2.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^28.1.0",
    "jsdom-global": "^3.0.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "rollup": "4.59.0",
    "ts-jest": "^29.4.6",
    "tslib": "^2.6.0",
    "typescript": "^4.8.4",
    "xstate": "^4.37.2"
  }
}
